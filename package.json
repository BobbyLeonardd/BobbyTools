    "proxy",
    "api",
    "rate-limit",
    "round-robin",
    "failover",
    "translation",
    "openrouter",
    "groq",
    "cloudflare",
    "aider",
    "opencode"
  ],
  "author": "Bobby Leonardo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bobbytools/bobbytools.git"
  },
  "homepage": "https://github.com/bobbytools/bobbytools#readme",
  "bugs": {
